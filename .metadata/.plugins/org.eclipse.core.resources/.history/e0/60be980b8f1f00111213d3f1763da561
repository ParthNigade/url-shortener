package com.parth.urlshortener.entity;

import jakarta.persistence.*;
import lombok.Data;

@Entity
@Table(name = "urls")
@Data
public class Url {

	@Id
	@GeneratedValue(strategy = GenerationType.IDENTITY)
	private Long id;
	
	private String originalUrl;
	
	@Column (unique = true)
	private String shortCode;
	
}
